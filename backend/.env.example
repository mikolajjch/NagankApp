# Copy this file as .env and fill in the values from the Auth0 Dashboard

AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://naganka-api

# Allowed frontend origins (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Optional: Postgres connection string for production (e.g. from Railway/Render).
# Leave unset to use a local SQLite file instead.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
